from transformers import AutoTokenizer, AutoModelForCausalLM
import torch
from sentence_transformers import SentenceTransformer, util

model_id = "mistralai/Mistral-7B-Instruct-v0.2"

tokenizer = AutoTokenizer.from_pretrained(model_id)
model = AutoModelForCausalLM.from_pretrained(
    model_id,
    torch_dtype=torch.float16,
    device_map="auto"
)

def generate(prompt, max_tokens=256):
    messages = [{"role": "user", "content": prompt}]

    input_text = tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )

    inputs = tokenizer(input_text, return_tensors="pt").to(model.device)

    outputs = model.generate(
        **inputs,
        max_new_tokens=max_tokens,
        temperature=0.3,
        top_p=0.9,
        do_sample=True,
        pad_token_id=tokenizer.eos_token_id
    )

    return tokenizer.decode(outputs[0], skip_special_tokens=True)

#Prompt Generation
prompt_fix_prompt = """You are processing text written in Romanized Odia (Odia language written in Latin script). Before responding, apply the following rules strictly and in order.
────────────────────────────────────────────
RULE 1 — WORD IDENTITY (counters: phonetic anchoring, script confusion)
────────────────────────────────────────────
For every unfamiliar or ambiguous word in the input, classify it into exactly one of:
[EN] — An English word (proper noun, borrowed term, brand, animal, object) used inside an Odia sentence. Examples: Kangaroo, Pizza, WhatsApp, Doctor.
[OR] — An Odia word written in Roman script.
[AMB] — Genuinely ambiguous; could be either.
Rules for [EN] classification:
- If the word has no known Odia equivalent AND has a clear English referent → [EN].
- Do NOT attempt to phonetically map an [EN] word onto an Odia word.
- Do NOT transliterate it into Odia script unless the user explicitly asks.
- Preserve it exactly as written.
Rules for [AMB]:
- Surface BOTH readings explicitly.
- Proceed with the most contextually supported reading, noting your choice.
────────────────────────────────────────────
RULE 2 — SUBWORD ASSEMBLY (counters: BPE tokenization mismatch)
────────────────────────────────────────────
Treat each written word as a complete semantic unit FIRST.
- Do NOT infer meaning from syllable-level substrings.
- If a word is partially familiar, prefer "unknown whole word" over "familiar fragment" as the basis for interpretation.
- When a word could be a compound Odia word, analyze it as a unit before splitting it.
────────────────────────────────────────────
RULE 3 — DIACRITIC DISAMBIGUATION (counters: retroflex/vowel-length collapse)
────────────────────────────────────────────
Apply this lookup before selecting any Odia word meaning:
Dental vs Retroflex:
  n → could be ନ (dental) or ଣ (retroflex)
  t → could be ତ (dental) or ଟ (retroflex)
  d → could be ଦ (dental) or ଡ (retroflex)
Vowel length:
  a → could be short ଅ or long ଆ
  i → could be short ଇ or long ଈ
  u → could be short ଉ or long ଊ
When the distinction changes the meaning, surface both candidates and select based on surrounding context.
If context is insufficient, state the ambiguity explicitly rather than silently picking one.
────────────────────────────────────────────
RULE 4 — CONFIDENCE TAGGING (counters: silent hallucination)
────────────────────────────────────────────
For any token where you applied [AMB] classification or a diacritic disambiguation, append a bracketed note inline explaining your choice. Do not produce a response with zero confidence notes if any Rule 2 or Rule 3 disambiguation was performed. Transparency beats fluency here."""

def generate_prompt():
    out = generate(prompt_fix_prompt, max_tokens=600)

    try:
        lines = out.split("\n")
        pid = ""
        fm = ""
        content = ""

        for line in lines:
            if line.startswith("PROMPT_ID"):
                pid = line.split(":",1)[1].strip()
            elif line.startswith("FAILURE_MODE"):
                fm = line.split(":",1)[1].strip()
            elif line.startswith("PROMPT"):
                content = out.split("PROMPT:",1)[1].strip()

        return {
            "prompt_id": pid if pid else f"id_{torch.randint(0,10000,(1,)).item()}",
            "failure_mode_targeted": fm if fm else "unknown",
            "prompt": content
        }

    except:
        return None

all_prompts = []

while len(all_prompts) < 50:
    p = generate_prompt()
    if p:
        all_prompts.append(p)
        print("Prompts:", len(all_prompts))

with open("lish_prompts_50.txt", "w", encoding="utf-8") as f:
    for i, p in enumerate(all_prompts, 1):
        f.write(f"--- Prompt {i} ---\n")
        f.write(f"prompt_id: {p['prompt_id']}\n")
        f.write(f"failure_mode_targeted: {p['failure_mode_targeted']}\n")
        f.write(f"prompt:\n{p['prompt']}\n\n")

print("Saved lish_prompts_50.txt")

#Evaluation
embed_model = SentenceTransformer('all-MiniLM-L6-v2')

def semantic_match(a, b):
    emb1 = embed_model.encode(a, convert_to_tensor=True)
    emb2 = embed_model.encode(b, convert_to_tensor=True)
    return util.cos_sim(emb1, emb2).item()

def evaluate_output(output, example):
    true_meaning = example["true_meaning"]

    sim = semantic_match(output, true_meaning)

    confused = example["wrong_english_mapping"].lower() in output.lower()

    return {
        "correct": sim > 0.6,
        "confused": confused
    }

def test_prompt(prompt, dataset):
    results = []

    for ex in dataset:
        inp = f"{prompt}\n\nInput word: {ex['indic_word']}"
        out = generate(inp, max_tokens=100)

        res = evaluate_output(out, ex)
        results.append(res)

    failures = sum([not r["correct"] for r in results])
    confusion = sum([r["confused"] for r in results])

    return {
        "failure_rate": failures / len(dataset),
        "confusion_rate": confusion / len(dataset)
    }

prompt_scores = []

for p in all_prompts:
    stats = test_prompt(p["prompt"], dataset)

    prompt_scores.append({
        "prompt_id": p["prompt_id"],
        "failure_mode": p["failure_mode_targeted"],
        "failure_rate": stats["failure_rate"],
        "confusion_rate": stats["confusion_rate"]
    })

with open("prompt_scores.txt", "w", encoding="utf-8") as f:
    for i, score in enumerate(prompt_scores, 1):
        f.write(f"--- Score {i} ---\n")
        f.write(f"prompt_id: {score['prompt_id']}\n")
        f.write(f"failure_mode: {score['failure_mode']}\n")
        f.write(f"failure_rate: {score['failure_rate']:.4f}\n")
        f.write(f"confusion_rate: {score['confusion_rate']:.4f}\n\n")

print("Saved prompt_scores.txt")
print("Done")
